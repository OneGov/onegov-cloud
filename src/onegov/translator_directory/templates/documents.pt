<div metal:use-macro="layout.base" i18n:domain="onegov.translator_directory">
    <tal:b metal:fill-slot="title">
        ${title}
    </tal:b>
    <tal:b metal:fill-slot="content">
        <div class="row">
            <div class="columns small-12">
                <div class="row">
                    <div class="columns small-12">
                        <h3 i18n:translate="">Upload</h3>
                         <label for="category" i18n:translate>Chose document category for upload: </label>

                        <select name="category" id="select-category">
                             <tal:b tal:repeat="category categories">
                                 <option tal:attributes="value layout.link_for(category); selected category == model.category">${category}</option>
                             </tal:b>
                        </select>

                        <tal:b metal:use-macro="layout.macros.upload" tal:define="upload_url layout.upload_url">
                                <tal:b metal:fill-slot="upload-filelist">
                                    <div class="upload-filelist-header" style="display: none;">
                                        <h3 i18n:translate>Just Uploaded</h3>
                                        <table class="files">
                                            <tr>
                                                <th i18n:translate>
                                                    Name
                                                </th>
                                                <th></th>
                                                <th i18n:translate>
                                                    Extension
                                                </th>
                                                <th i18n:translate>
                                                    Upload Date
                                                </th>
                                            </tr>
                                            <tbody class="upload-filelist"></tbody>
                                        </table>
                                    </div>
                                </tal:b>
                            </tal:b>

                        <h3 i18n:translate>Files by category</h3>
                        <tal:b condition="not:grouped">
                            <p i18n:translate="">No files uploaded yet</p>
                        </tal:b>
                        <table tal:condition="grouped"
                               class="files translator-documents">
                            <tbody>
                                <tal:b tal:repeat="(category, files) grouped">
                                    <tr>
                                        <th>${category}</th>
                                        <th></th>
                                        <th i18n:translate>Extension</th>
                                        <th i18n:translate>Upload Date</th>
                                        <th i18n:translate>Move</th>
                                    </tr>
                                    <tal:b tal:repeat="file files">
                                        <tr class="file-info ${'signed' if file.signed else ''}"
                                            tal:define="file_upload file.upload_date|file.created">
                                            <td>${file.name}</td>
                                            <td>
                                                <a id="button-${file.id}"
                                                   data-ogc-toggle="#details-${file.id}">
                                                    <i class="fa fa-chevron-down rotate"
                                                       aria-hidden="true"></i>
                                                </a>
                                            </td>
                                            <td>${extension(file)}</td>
                                            <td>${format_date(file_upload)}</td>
                                            <td>
                                                <form class="move-category-form"
                                                      method="POST"
                                                      action="${move_url}">
                                                    <input type="hidden"
                                                           name="file_id"
                                                           value="${file.id}" />
                                                    <select name="new_category"
                                                            class="move-category-select">
                                                        <option tal:repeat="cat categories"
                                                                tal:attributes="value cat;
                                                                               selected cat == file.note"
                                                                >${cat}</option>
                                                    </select>
                                                </form>
                                            </td>
                                        </tr>
                                        <tr id="details-${file.id}" class="hidden">
                                            <td colspan="5">
                                                <div ic-trigger-from="#button-${file.id}"
                                                     ic-trigger-on="click once, change"
                                                     ic-get-from="${actions_url(file.id)}"
                                                     class="file-preview-wrapper">
                                                </div>
                                            </td>
                                        </tr>
                                    </tal:b>
                                </tal:b>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </tal:b>
</div>
