<div metal:use-macro="layout.base" i18n:domain="onegov.feriennet">
    <tal:b metal:fill-slot="title">
        ${layout.title}
    </tal:b>

    <tal:b metal:fill-slot="content">

        <div class="panel callout">
            <tal:b tal:condition="form.has_recipients"  i18n:translate>
            Clicking "Send E-Mail Now" will send the e-mail below to all selected recipients. You will receive a copy of the e-mail if you are not already on the recipients list.
            </tal:b>
            <tal:b tal:condition="not:form.has_recipients" i18n:translate>
                There are no subscriptions for this course event.
            </tal:b>
        </div>

        <div class="notification-preview">
            <tal:b metal:use-macro="layout.macros['email_preview']" />
        </div>

        <tal:b tal:condition="form.has_recipients" metal:use-macro="layout.macros['form']" />
    </tal:b>
</div>
