#, python-format
msgid "The file is too large, please provide a file smaller than {}."
msgstr "Il file è memia grond, per plaschair furnescha in file pli pitschen che {}."

msgid ""
"The password you wanted to use was found on list of commonly used passwords, "
"please use a more secure password."
msgstr ""
"Il pled-clav che ti vulevas duvrar vegnà retschertgà sin la glista dals "
"pled-clav bler dovrats, per plaschair duvra in pled-clav pli segir."

msgid "The form could not be parsed."
msgstr "Il formular na posseda betg vegnir parsà."

msgid "Define at least one required e-mail field ('E-Mail * = @@@')"
msgstr "Definischa almain in champ d'e-mail obligatori ('E-Mail * = @@@')"

#, python-format
msgid "The syntax on line {line} is not valid."
msgstr "La sintaxis sin la linha {line} n'è betg valaivla."

#, python-format
msgid ""
"The indentation on line {line} is not valid. Please use a multiple of 4 "
"spaces"
msgstr ""
"L'indentaziun sin la linha {line} n'è betg valaivla. Per plaschair duvrar in "
"multiplicativ da 4 spazis."

#, python-format
msgid ""
"The indentation on line {line} is not valid. Comments must be indented to "
"the same level as the field definition (`=`) they belong to."
msgstr ""
"L'indentaziun sin la linha {line} n'è betg valaivla. Ils commentaris ston "
"esser indentads al medem nivel sco la definiziun dal champ (`=`) a la quala "
"els appatgnan."

#, python-format
msgid ""
"Incorrect placement of the field description on line {line}. The field "
"description must be placed below the field definition (`=`) and with the "
"same indentation."
msgstr ""
"Posiziun sbagliada da la descripziun dal champ sin la linha {line}. La "
"descripziun sto star sut la definiziun dal champ (`=`) e cun la medema "
"indentaziun."

#, python-format
msgid "The field '{label}' exists more than once."
msgstr "Il champ '{label}' exista pliras giadas."

#, python-format
msgid "'{label}' is a reserved name. Please use a different name."
msgstr "'{label}' è in num reservà. Per plaschair duvra in auter num."

msgid "Define at least one required field"
msgstr "Definischa almain in champ obligatori"

#, python-format
msgid ""
"The field '{label}' contains a price that requires a credit card payment. "
"This is only allowed if credit card payments are optional."
msgstr ""
"Il champ '{label}' cuntegna in prezi che basegns pgiaments cun carta da "
"credit. Quai è be pussaivel sch'ils pgiaments cun carta da credit èn "
"opzional."

msgid ""
"A minimum price total can only be set if at least one priced field is "
"defined."
msgstr ""
"In total da prezi minimal po vegnir definì be sch'almain in champ cun prezi "
"è definì."

#, python-format
msgid ""
"The '{label}' group is empty and will not be visible. Either remove the "
"empty group or add fields to it."
msgstr ""
"Il grupp '{label}' è vid e na vegn betg mussà. Elimina il grupp vid ni "
"agiunta champs."

#, python-format
msgid ""
"${fields}: New fields cannot be required initially. Require them in a "
"separate migration step."
msgstr ""
"${fields}: Novs champs na pon betg vegnir obligatg en l'inizial. Oblitg'els "
"en in pass da migraziun separat."

#, python-format
msgid ""
"Invalid field type for field '{label}'. For filters only 'select' or "
"'multiple select' fields are allowed."
msgstr ""
"Tip da champ invalid per il champ '{label}'. Per filters èn mo 'select' u "
"'multiple select' pussaivels."

#, python-format
msgid ""
"Invalid field type for field '${label}'. Please use the plus-icon to add "
"allowed field types."
msgstr ""
"Tip da champ invalid per il champ '${label}'. Per plaschair dovra l'icon "
"plus per agiuntar tips da champs permess."

msgid "Not a valid phone number."
msgstr "Numer da telefon nunvalaivel."

msgid "Not a valid swiss social security number."
msgstr ""

msgid "This value already exists."
msgstr "Questa valur exista gia."

#, python-format
msgid "Needs to be between {min_date} and {max_date}."
msgstr "Sto esser tranter {min_date} e {max_date}."

#, python-format
msgid "Needs to be on or after {date}."
msgstr "Sto esser ils u suenter {date}."

#, python-format
msgid "Needs to be on or before {date}."
msgstr "Sto esser ils u avant {date}."

msgid "Not a valid domain."
msgstr "Na è betg in domini valid."

msgid "Uploaded file"
msgstr "File chargà"

msgid "Keep file"
msgstr "Mantgna file"

msgid "Delete file"
msgstr "Smanatga file"

msgid "Replace file"
msgstr "Replazza file"

msgid "Upload additional files"
msgstr "Chargia ulteriurs files"

msgid "Text modules"
msgstr "Moduls da text"

msgid "Select an Option"
msgstr "Tscherna ina opziun"

msgid "No results match"
msgstr "Nagins resultads correspundan"

msgid "Select Some Options"
msgstr "Tscherna intginas opziuns"

msgid "hours"
msgstr "oras"

msgid "minutes"
msgstr "minuts"
