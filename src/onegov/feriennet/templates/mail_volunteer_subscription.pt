<div metal:use-macro="layout.base" i18n:domain="onegov.feriennet">
    <tal:b metal:fill-slot="title">
        ${title}
    </tal:b>
    <tal:b metal:fill-slot="body">
        <tal:b tal:replace="custom_text_before_list" />
        <tal:b condition="not custom_text_before_list">
            <p i18n:translate>Hello!</p>
            <p i18n:translate>You have subscribed to the following needs:</p>
        </tal:b>
        <ul class="normal">
            <tal:needs repeat="subscription subscriptions">
                <li>
                    <b>${subscription.need.name}</b> - <a href="${request.link(subscription.need.occasion.activity)}">
                        ${subscription.need.occasion.activity.title}
                    </a>
                    <br>
                    <tal:b tal:repeat="date subscription.need.occasion.dates">${layout.format_datetime_range(date.localized_start, date.localized_end)}</tal:b>
                </li>
            </tal:needs>
        </ul>
        <tal:b tal:replace="custom_text_after_list" />
        <tal:b condition="not custom_text_after_list">
            <p i18n:translate>Thank you for offering to volunteer! We will have a look at your request and get back to you.</p>
        </tal:b>
    </tal:b>
</div>
