<div metal:use-macro="layout.base" i18n:domain="onegov.org">
    <tal:b metal:fill-slot="title">
        ${title}
    </tal:b>
    <tal:b metal:fill-slot="content">
        <div class="small-12 medium-10 large-8 columns">
            <tal:b tal:condition="python:len(reservations) == 1">
                <p i18n:translate>
                    You are about to submit a cancellation request for the following reservation. An administrator will review your request and confirm the cancellation.
                </p>
                <p><b>${resource.title}</b></p>
                <tal:b metal:use-macro="layout.macros['reservations']"></tal:b>
            </tal:b>

            <tal:b tal:condition="python:len(reservations) > 1">
                <p i18n:translate>
                    Please select the reservations you would like to cancel. An administrator will review your request and confirm the cancellation.
                </p>
                <p><b>${resource.title}</b></p>
            </tal:b>

            <div metal:use-macro="layout.macros['form']" />
        </div>
    </tal:b>
</div>
