<div metal:use-macro="layout.base" i18n:domain="onegov.org">
    <tal:b metal:fill-slot="title">
        ${title}
    </tal:b>
    <tal:b metal:fill-slot="body">
        <tal:b condition="deleted">
            <p><tal:b i18n:translate="">The entry "<tal:b i18n:name="entry">${entry_title}</tal:b>" in the "<tal:b i18n:name="directory">${directory.title}</tal:b>" directory has been deleted.</tal:b>
            <tal:b condition="auto_deleted"><br/><span i18n:translate>Automatically deleted as configured.</span></tal:b></p>
        </tal:b>
        <tal:b condition="not: deleted">
            <p><tal:b i18n:translate="">The publication period of the entry "<tal:b i18n:name="entry">${entry_title}</tal:b>" in the "<tal:b i18n:name="directory">${directory.title}</tal:b>" directory has ended.</tal:b></p>
        </tal:b>
        <p>
            <span i18n:translate="">Publication start:</span>
            <tal:b condition="publication_start | nothing"> ${layout.format_date(publication_start, 'datetime_long')}</tal:b>
            <tal:b condition="not: publication_start | nothing"> <span i18n:translate="">Not set</span></tal:b><br/>
            <span i18n:translate="">Publication end:</span>
            <tal:b condition="publication_end | nothing"> ${layout.format_date(publication_end, 'datetime_long')}</tal:b>
            <tal:b condition="not: publication_end | nothing"> <span i18n:translate="">Not set</span></tal:b><br/>
            Hash: ${content_hash}
        </p>
        <p><tal:b i18n:translate="">Email automatically generated by <tal:b i18n:name="org">${layout.org.title}</tal:b> at <tal:b i18n:name="timestamp">${layout.format_date(generated_at, 'datetime_long')}</tal:b></tal:b></p>
    </tal:b>
</div>
