<div metal:use-macro="layout.base" i18n:domain="onegov.town6">
    <tal:b metal:fill-slot="title">
        ${title}
    </tal:b>

    <tal:b metal:fill-slot="content">
        <div class="grid-x grid-padding-x">
            <div class="large-8 medium-8 cell main-content">
                <div tal:condition="commission.memberships">
                    <h2 i18n:translate class="h3">Parliamentarians</h2>
                    <dd>
                        <ul class="more-list">
                            <li tal:repeat="membership memberships">
                                <a href="${request.link(membership.parliamentarian)}" class="list-link">
                                    <span tal:content="membership.parliamentarian.title" class="list-title"></span>
                                </a>
                                <span class="list-lead preview">
                                    ${membership.role_label}
                                    <tal:b tal:condition="membership.start or membership.end">
                                        (${layout.format_date_range(membership.start, membership.end)})
                                    </tal:b>
                                </span>
                            </li>
                        </ul>
                    </dd>
                </div>
            </div>
            <div class="large-4 medium-4 cell sidebar filter-panel">
                <div class="sidebar-wrapper">
                    <div class="side-panel">
                        <div tal:condition="commission.description">
                            <h2 class="h3" i18n:translate>Contact</h2>
                            <div>${commission.description}</div>
                        </div>
                        <div tal:condition="commission.start">
                            <h6 i18n:translate>Start</h6>
                            <p>${layout.format_date(commission.start, 'date')}</p>
                        </div>
                        <div tal:condition="commission.end">
                            <h6 i18n:translate>End</h6>
                            <p>${layout.format_date(commission.end, 'date')}</p>
                        </div>
                        <h2 i18n:translate class="h3">Filters</h2>
                        <div metal:use-macro="layout.macros['tags']" tal:define="tags filters['active']" />
                    </div>
                </div>
            </div>
        </div>
    </tal:b>
</div>
