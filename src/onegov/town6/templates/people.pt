<div metal:use-macro="layout.base" i18n:domain="onegov.town6">
    <tal:b metal:fill-slot="title">
        ${title}
    </tal:b>
    <tal:b metal:fill-slot="content">

        <div class="grid-x">
            <div class="cell small-12 medium-6 large-4">
                <form method="get" id="people-filters">
                    <input type="search" name="search"
                           style="font-family: inherit"
                           tal:attributes="value selected_search"
                           i18n:attributes="placeholder"
                           placeholder="Search people"/>
                    <tal:b tal:condition="organisations">
                        <label><span class="label-text" i18n:translate="">Filter after Organisation or Suborganisation</span></label>
                        <select class="people-filter-select" name="organisation" i18n:attributes="title" title="Select organisation" data-auto-submit>
                            <option value="" i18n:translate="">Select organisation</option>
                            <tal:block tal:repeat="org organisations">
                                <option tal:attributes="value org; selected python:org == selected_organisation">${org}</option>
                            </tal:block>
                        </select>
                        <select class="people-filter-select" name="sub_organisation" i18n:attributes="title" title="Select sub organisation" data-auto-submit>
                            <option value="" i18n:translate="">Select sub organisation</option>
                            <tal:block tal:repeat="sub_org sub_organisations">
                                <option tal:attributes="value sub_org; selected python:sub_org == selected_sub_organisation">${sub_org}</option>
                            </tal:block>
                        </select>
                    </tal:b>
                </form>
            </div>
        </div>

        <tal:b tal:condition="python: not people and not (selected_organisation or selected_sub_organisation or selected_search)">
            <p class="panel" i18n:translate="">No people added yet.</p>
        </tal:b>
        <tal:b tal:condition="python: not people and (selected_organisation or selected_sub_organisation or selected_search)">
            <p class="panel" i18n:translate="">No people found for current filter selection.</p>
            <a class="button hollow" href="${request.class_link(layout.model.__class__)}" i18n:translate>Reset filter</a>
        </tal:b>

        <div tal:condition="people" class="people-list">
            <div metal:use-macro="layout.macros['atoz']" tal:define="items people">
                <tal:b metal:fill-slot="item-detail">
                    <div metal:use-macro="layout.macros['person_list_card']" tal:define="person detail"/>
                </tal:b>
            </div>
        </div>
    </tal:b>
</div>
